pipeline {
    agent any
    
    stages {
        stage('Checkout') {
            steps {
                // Download code from Bitbucket
                git 'https://bitbucket.org/your-repo.git'
            }
        }
        
        stage('SonarQube Analysis') {
            steps {
                // Run SonarQube analysis
                withSonarQubeEnv('SonarQube Server') {
                    sh 'mvn sonar:sonar'
                }
            }
        }
        
        stage('Run Tests') {
            steps {
                // Execute tests
                sh 'mvn test'
            }
        }
        
        stage('FTP Upload') {
            steps {
                // Send COBOL files via FTP to a specific server
                sh 'ftp -n <<EOF\nopen ftp.example.com\nuser username password\nput file.cob\nquit\nEOF'
            }
        }
    }
}