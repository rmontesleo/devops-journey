pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                // Download the source code from Bitbucket
                git 'https://bitbucket.org/your-repo.git'
            }
        }

        stage('Compile') {
            steps {
                // Compile the code
                sh 'make'
            }
        }

        stage('Unit Tests') {
            steps {
                // Execute unit tests
                sh './run_tests.sh'
            }
        }

        stage('SonarQube') {
            steps {
                // Invoke SonarQube analysis
                withSonarQubeEnv('SonarQube Server') {
                    sh 'sonar-scanner'
                }
            }
        }

        stage('Upload to FTP') {
            steps {
                // Zip the files
                sh 'zip -r project.zip .'

                // Upload the zip file to a remote server via FTP
                ftpPublish(
                    remote: 'ftp.example.com',
                    credentialsId: 'ftp-credentials',
                    sourceFiles: 'project.zip',
                    remoteDirectory: '/path/to/remote/directory'
                )
            }
        }
    }
}